{
  "version": 2,
  "buildCommand": "cd frontend && ls -la",
  "outputDirectory": "frontend",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://your-backend-railway.app/api/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "^/(?!api|static).*",
      "dest": "/index.html"
    }
  ]
}
